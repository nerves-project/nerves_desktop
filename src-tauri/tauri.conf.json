{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Nerves Desktop",
  "version": "0.1.0",
  "identifier": "org.nerves-project.NervesDesktop",
  "build": {
    "beforeBuildCommand": "mix do compile + assets.deploy + release --overwrite --path src-tauri/target/rel",
    "beforeDevCommand": "mkdir -p src-tauri/target/rel"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "target/rel": "rel"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
